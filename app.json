{
  "expo": {
    "name": "Kadim Meşe Hanı",
    "slug": "kadim-mese-hani",
    "scheme": "kadimhani",
    "version": "1.0.2",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./src/assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kadim.mesehani",
      "icon": {
        "light": "./src/assets/icon.png",
        "dark": "./src/assets/icon-dark.png",
        "tinted": "./src/assets/icon-tinted.png"
      }
    },
    "android": {
      "package": "com.kadim.mesehani",
      "versionCode": 3,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#110d0a",
        "monochromeImage": "./src/assets/adaptive-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#14100c",
          "image": "./src/assets/logo.png",
          "imageWidth": 250,
          "dark": {
            "backgroundColor": "#14100c",
            "image": "./src/assets/logo.png",
            "imageWidth": 250
          }
        }
      ],
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ],
      "expo-system-ui",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "src/app"
      },
      "eas": {
        "projectId": "67cc3a03-c67e-482b-9ab4-123e87880d2d"
      }
    }
  }
}
